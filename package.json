{
  "name": "db-cluster",
  "version": "0.1.0",
  "description": "AI-native federated database cluster with typed errors, mutation receipts, and MCP/SDK/CLI surfaces — for AI agents needing trustworthy retrieval and operators needing safe writes.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    },
    "./policy": {
      "types": "./dist/policy/index.d.ts",
      "import": "./dist/policy/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    }
  },
  "bin": {
    "db-cluster": "dist/cli.js",
    "db-cluster-mcp": "dist/mcp/server.js"
  },
  "files": [
    "dist/",
    "docs/",
    "examples/",
    "dashboard/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:mutation": "stryker run",
    "lint": "tsc --noEmit && npm run lint:examples",
    "lint:examples": "tsc -p tsconfig.examples.json",
    "prepack": "npm run build",
    "prepublishOnly": "node scripts/release-gate.mjs",
    "smoke:pack": "npm pack --dry-run",
    "release-gate": "node scripts/release-gate.mjs",
    "completeness": "node scripts/completeness-checks.mjs"
  },
  "keywords": [
    "ai",
    "ai-agent",
    "mcp",
    "model-context-protocol",
    "claude",
    "database",
    "federated",
    "truth-store",
    "provenance",
    "audit",
    "receipts",
    "evidence",
    "verification",
    "policy",
    "redaction",
    "cluster",
    "graph",
    "typescript",
    "nodejs",
    "cli"
  ],
  "author": "mcp-tool-shop <64996768+mcp-tool-shop@users.noreply.github.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mcp-tool-shop-org/db-cluster.git"
  },
  "bugs": "https://github.com/mcp-tool-shop-org/db-cluster/issues",
  "homepage": "https://github.com/mcp-tool-shop-org/db-cluster#readme",
  "devDependencies": {
    "@ast-grep/cli": "^0.43.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "fast-check": "^4.8.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "pg": "^8.21.0"
  }
}
