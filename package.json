{
  "name": "db-cluster",
  "version": "0.1.0",
  "description": "AI-native federated database cluster — specialized truth stores behaving as one governed substrate.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    },
    "./policy": {
      "types": "./dist/policy/index.d.ts",
      "import": "./dist/policy/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    }
  },
  "bin": {
    "db-cluster": "dist/cli.js",
    "db-cluster-mcp": "dist/mcp/server.js"
  },
  "files": [
    "dist/",
    "docs/",
    "examples/",
    "dashboard/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepack": "npm run build",
    "smoke:pack": "npm pack --dry-run",
    "release-gate": "node scripts/release-gate.mjs"
  },
  "keywords": [
    "ai",
    "database",
    "federated",
    "truth-store",
    "provenance",
    "cluster",
    "mcp"
  ],
  "author": "mcp-tool-shop <64996768+mcp-tool-shop@users.noreply.github.com>",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "pg": "^8.21.0"
  }
}
